<div id="<%= dom_id tenant %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Stripe customer:</strong>
    <%= tenant.stripe_customer_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= tenant.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Corporate name:</strong>
    <%= tenant.corporate_name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Cnpj:</strong>
    <%= tenant.cnpj %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Address:</strong>
    <%= tenant.address %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Representative name:</strong>
    <%= tenant.representative_name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Representative cpf:</strong>
    <%= tenant.representative_cpf %>
  </div>
</div>
