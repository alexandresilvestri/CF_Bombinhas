<div id="<%= dom_id workout %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Tenant:</strong>
    <%= workout.tenant_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= workout.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Start time:</strong>
    <%= workout.start_time %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Max capacity:</strong>
    <%= workout.max_capacity %>
  </div>
</div>
