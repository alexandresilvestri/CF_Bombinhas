<div class="mb-4">
  <%= link_to "← Voltar", workout_weekly_schedules_path, class: "text-blue-600 hover:underline" %>
</div>

<div class="border rounded p-6 max-w-md bg-white">
  <h1 class="text-2xl font-bold mb-4">
    <%= t(@schedule.week_days, scope: "activerecord.attributes.workout_weekly_schedules").capitalize %>
  </h1>

  <dl class="space-y-2">
    <div>
      <dt class="font-semibold">Horário</dt>
      <dd><%= @schedule.start_time.strftime("%H:%M") %></dd>
    </div>
    <div>
      <dt class="font-semibold">Vagas</dt>
      <dd><%= @schedule.max_capacity %></dd>
    </div>
  </dl>

  <% if can_manage? %>
    <div class="flex gap-2 mt-6">
      <%= link_to "Editar", edit_workout_weekly_schedule_path(@schedule),
          class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
      <%= button_to "Excluir", workout_weekly_schedule_path(@schedule),
          method: :delete,
          data: { turbo_confirm: "Tem certeza que deseja excluir este horário?" },
          class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
